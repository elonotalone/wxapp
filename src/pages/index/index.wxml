<view class="page">
  <view class="hero">
    <view class="hero-title">My WxApp</view>
    <view class="hero-subtitle">OceanDino × WeChat Mini Program</view>
  </view>

  <view class="card">
    <view class="card-title">点击计数 Demo</view>
    <view class="counter">{{count}}</view>
    <view class="actions">
      <button class="btn btn-primary" bindtap="onIncrement">+1</button>
      <button class="btn btn-ghost" bindtap="onReset">Reset</button>
    </view>
  </view>

  <view class="card">
    <view class="card-title">输入回显</view>
    <input class="input" placeholder="说点什么..." value="{{message}}" bindinput="onInput" />
    <view class="echo" wx:if="{{message}}">你说: {{message}}</view>
  </view>

  <view class="footnote">
    Powered by glass-easel · 浏览器预览,vibe coding 用
  </view>
</view>
