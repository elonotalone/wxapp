.page {
  min-height: 100vh;
  padding: 40rpx 32rpx 80rpx;
  box-sizing: border-box;
}

.hero {
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #0f172a;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748b;
}

.card {
  margin-top: 28rpx;
  padding: 32rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 24rpx;
}

.counter {
  font-size: 96rpx;
  font-weight: 800;
  color: #0ea5e9;
  text-align: center;
  margin: 8rpx 0 28rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx;
  border: none;
  padding: 0;
}

.btn-primary {
  background: #0ea5e9;
  color: #ffffff;
}

.btn-primary:active {
  background: #0284c7;
}

.btn-ghost {
  background: #e2e8f0;
  color: #1f2937;
}

.btn-ghost:active {
  background: #cbd5e1;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.echo {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #475569;
}

.footnote {
  margin-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
}
